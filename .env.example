# Optional YouTube Data API key. When provided, metadata search can use the
# official YouTube Data API before falling back to ytmusicapi / yt-dlp.
YOUTUBE_DATA_API_KEY=

# Search provider order. Default is auto.
# auto | qqmusic | youtube
# Legacy YouTube internals are still available for compatibility:
# youtube_data_api | ytmusicapi | legacy_ytdlp
NAS_SEARCH_PROVIDER=auto

# Keep YouTube / YT Music as a fallback after QQ Music in auto/qqmusic mode.
NAS_ENABLE_YOUTUBE_FALLBACK=true

# Metadata requests transport mode.
# auto | system | direct | custom
NAS_METADATA_PROXY_MODE=auto

# Media delivery mode for playback and download fallback.
# auto | direct | proxy
NAS_MEDIA_TRANSPORT=auto

# Optional custom proxy used when NAS_METADATA_PROXY_MODE=custom or
# NAS_MEDIA_TRANSPORT needs a custom fallback.
NAS_CUSTOM_PROXY_URL=

# Optional metadata search locale tuning.
NAS_SEARCH_REGION=CN
NAS_SEARCH_LANGUAGE=zh-CN
